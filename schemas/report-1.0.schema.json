{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Love-Ash/archforge/blob/main/schemas/report-1.0.schema.json",
  "title": "archforge single-file report, schema 1.0 (stable through 1.x)",
  "type": "object",
  "required": ["schema_version", "tool", "file", "errors", "warnings", "summary"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "tool": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {"name": {"const": "archforge"}, "version": {"type": "string"}}
    },
    "target_renderer": {"type": "string"},
    "file": {"type": "string"},
    "lang": {"type": "string", "enum": ["ko", "en"]},
    "errors": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "warnings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "ghost": {"type": "array"},
    "summary": {
      "type": "object",
      "required": ["error_count", "warn_count", "pass", "incomplete", "policy",
                   "profile", "skipped_codes"],
      "properties": {
        "error_count": {"type": "integer", "minimum": 0},
        "warn_count": {"type": "integer", "minimum": 0},
        "pass": {"type": "boolean"},
        "incomplete": {"type": "boolean"},
        "policy": {"type": "object"},
        "profile": {"type": "string"},
        "skipped_codes": {"type": "array"},
        "baseline_suppressed": {"type": "integer", "minimum": 0},
        "config": {"type": ["string", "null"]}
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["page", "code", "message"],
      "properties": {
        "page": {"type": "integer", "minimum": 0},
        "code": {"type": "string", "pattern": "^[EW][0-9]{1,2}$"},
        "message": {"type": "string"},
        "detail": {"type": "string"},
        "location": {"type": "object"}
      }
    }
  }
}
